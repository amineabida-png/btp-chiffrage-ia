# Base de données PostgreSQL (fournie automatiquement par Railway)
DATABASE_URL="postgresql://user:password@host:5432/btp_chiffrage"

# NextAuth - secret de session (générer avec: openssl rand -base64 32)
NEXTAUTH_SECRET="changez-moi-par-un-secret-aleatoire-long"
NEXTAUTH_URL="http://localhost:3000"

# ===== GROQ (100% GRATUIT) =====
# Créez une clé sur https://console.groq.com/keys
GROQ_API_KEY="gsk_xxxxxxxxxxxxxxxxxxxxxxxx"

# Modèle texte (raisonnement, extraction, chiffrage, risques)
GROQ_MODEL="openai/gpt-oss-120b"

# Modèle vision (OCR images/scans + lecture des plans) — multimodal
GROQ_VISION_MODEL="qwen/qwen3.6-27b"

# ===== RECHERCHE SÉMANTIQUE (embeddings) =====
# Par défaut: modèle LOCAL gratuit (aucune clé). Laissez "local".
EMBEDDINGS_PROVIDER="local"
EMBEDDINGS_MODEL="Xenova/paraphrase-multilingual-MiniLM-L12-v2"
# Option hébergée gratuite (si vous préférez ne pas charger le modèle localement):
# EMBEDDINGS_PROVIDER="jina"
# JINA_API_KEY="jina_xxxxxxxx"   (clé gratuite sur https://jina.ai/embeddings)
